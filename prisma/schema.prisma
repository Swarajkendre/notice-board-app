// Prisma schema for the Reno Notice Board
// Database: TiDB Cloud (MySQL-compatible)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("mysql://P5oEDLEtaqDenDb.root:DgLqm41xsPofwqdU@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/sys")
}

model Notice {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(150)
  content     String   @db.Text
  category    String   @default("General") @db.VarChar(20)
  isUrgent    Boolean  @default(false)
  publishDate DateTime @default(now())
  imageUrl    String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Urgent notices first, then newest by publish date
  @@index([isUrgent, publishDate])
  @@map("notices")
}
